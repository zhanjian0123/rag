# ==================== LLM 配置 ====================
# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# 通义千问（DashScope）配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# LLM 提供商选择：openai | dashscope
LLM_PROVIDER=dashscope

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./web_rag.db
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ==================== 检索配置 ====================
# 是否启用 Reranker 重排序
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K=5

# 检索返回数量
DENSE_TOP_K=15
SPARSE_TOP_K=15
RERANK_TOP_K=5

# 混合检索权重（向量检索权重，BM25 权重 = 1 - 此值）
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3

# ==================== 切片策略配置 ====================
# 切片策略：sentence | paragraph | semantic | markdown | fixed | hybrid
CHUNK_STRATEGY=hybrid

# 切片大小（字符数）
CHUNK_SIZE=500

# 切片重叠（字符数）
CHUNK_OVERLAP=100

# Markdown 是否按标题层级切片
MD_CHUNK_BY_HEADER=true

# ==================== 查询优化配置 ====================
# 是否启用查询重写
ENABLE_QUERY_REWRITE=true

# 是否启用 HyDE（Hypothetical Document Embeddings）
ENABLE_HYDE=false

# 是否启用子查询分解
ENABLE_QUERY_DECOMPOSE=false

# ==================== 应用配置 ====================
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 网页提取配置 ====================
TRAFILATURA_TIMEOUT=30
TRAFILATURA_MAX_RETRIES=3
